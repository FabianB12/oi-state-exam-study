flowchart LR
  NTM["<b>Polynomial-time NTM</b><br/>M accepts x in at most p(n) steps"]
  Tableau["<b>Computation tableau</b><br/>rows = time steps<br/>columns = tape cells<br/>local constraints enforce legal moves"]
  Formula["<b>SAT formula</b><br/>variables encode symbols, states, heads<br/>satisfiable iff accepting tableau exists"]
  Result["<b>Cook-Levin</b><br/>every NP computation reduces to SAT<br/>therefore SAT is NP-complete"]

  NTM --> Tableau --> Formula --> Result

  classDef blue fill:#EFF6FF,stroke:#2563EB,color:#172033,stroke-width:2px;
  classDef green fill:#F0FDF4,stroke:#16A34A,color:#172033,stroke-width:2px;
  classDef yellow fill:#FEFCE8,stroke:#CA8A04,color:#172033,stroke-width:2px;
  classDef red fill:#FFF1F2,stroke:#E11D48,color:#172033,stroke-width:2px;
  class NTM blue;
  class Tableau green;
  class Formula yellow;
  class Result red;
