flowchart LR
  Agent["<b>Agent</b><br/>policy pi(s)<br/>value V(s)<br/>action-value Q(s,a)"]
  Env["<b>Environment</b><br/>transition model P(s'|s,a)<br/>reward R(s,a,s')"]
  Update["<b>Learning update</b><br/>Q-learning target:<br/>r + gamma max Q(next,a)<br/>SARSA target:<br/>r + gamma Q(next, actual action)"]

  Agent -- "choose action a" --> Env
  Env -- "reward r and next state s'" --> Agent
  Env --> Update
  Update --> Agent

  classDef blue fill:#EFF6FF,stroke:#2563EB,color:#172033,stroke-width:2px;
  classDef green fill:#F0FDF4,stroke:#16A34A,color:#172033,stroke-width:2px;
  classDef neutral fill:#F8FAFC,stroke:#64748B,color:#172033,stroke-width:2px;
  class Agent blue;
  class Env green;
  class Update neutral;
