flowchart LR
  Formula["<b>Formula</b><br/>propositional logic<br/>or first-order logic"]
  Normal["<b>Normal form</b><br/>NNF, CNF<br/>clauses"]
  Search["<b>Search</b><br/>resolution<br/>DPLL / CDCL"]
  Contradiction["<b>Contradiction</b><br/>empty clause<br/>UNSAT"]
  Model["<b>Model</b><br/>satisfying assignment<br/>or grounded model"]
  Note["<b>FOL detail</b><br/>Unification makes literals match.<br/>Finite domains can be grounded to SAT."]

  Formula --> Normal --> Search
  Search --> Contradiction
  Search --> Model
  Search --> Note

