  classDef yellow fill:#FEFCE8,stroke:#CA8A04,color:#172033,stroke-width:2px;
  classDef red fill:#FFF1F2,stroke:#E11D48,color:#172033,stroke-width:2px;
  classDef neutral fill:#F8FAFC,stroke:#64748B,color:#172033,stroke-width:2px;
  class Formula,Model blue;
  class Normal green;
  class Search yellow;
  class Contradiction red;
