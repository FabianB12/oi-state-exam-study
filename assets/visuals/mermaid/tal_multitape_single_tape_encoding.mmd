flowchart TB
  subgraph Multi["Multitape machine step"]
    T1["<b>Tape 1</b><br/>... a [b] c ..."]
    T2["<b>Tape 2</b><br/>... 0 [1] _ ..."]
    T3["<b>Tape 3</b><br/>... x [y] z ..."]
  end

  Encode["<b>Encode all tapes on one tape</b><br/>separate tracks by delimiters<br/>mark each simulated head position"]

  Single["<b>Single-tape simulation</b><br/># ... a [b] c ... # ... 0 [1] _ ... # ... x [y] z ... #<br/>one simulated multitape step may require a full scan"]

  Cost["<b>Why this is okay for complexity classes</b><br/>simulation may be slower<br/>but polynomial time remains polynomial time"]

  T1 --> Encode
  T2 --> Encode
  T3 --> Encode
  Encode --> Single --> Cost

  classDef blue fill:#EFF6FF,stroke:#2563EB,color:#172033,stroke-width:2px;
  classDef green fill:#F0FDF4,stroke:#16A34A,color:#172033,stroke-width:2px;
  classDef yellow fill:#FEFCE8,stroke:#CA8A04,color:#172033,stroke-width:2px;
  classDef neutral fill:#F8FAFC,stroke:#64748B,color:#172033,stroke-width:2px;
  class T1,T2,T3 blue;
  class Encode yellow;
  class Single green;
  class Cost neutral;
