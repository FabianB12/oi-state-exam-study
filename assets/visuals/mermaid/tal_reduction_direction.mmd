flowchart LR
  A["<b>Known hard problem A</b><br/>for example SAT or 3-SAT"]
  Map["<b>Polynomial mapping f</b><br/>x is in A iff f(x) is in B"]
  B["<b>Target problem B</b><br/>problem we want to prove hard"]
  Solver["<b>If B had a fast solver</b><br/>solve A by transforming x to f(x)<br/>then running the solver for B"]
  Warn["<b>Exam warning</b><br/>for NP-hardness reduce<br/>from known hard A to target B"]

  A --> Map --> B --> Solver
  Map --> Warn

  classDef blue fill:#EFF6FF,stroke:#2563EB,color:#172033,stroke-width:2px;
  classDef green fill:#F0FDF4,stroke:#16A34A,color:#172033,stroke-width:2px;
  classDef yellow fill:#FEFCE8,stroke:#CA8A04,color:#172033,stroke-width:2px;
  classDef red fill:#FFF1F2,stroke:#E11D48,color:#172033,stroke-width:2px;
  class A blue;
  class Map green;
  class B yellow;
  class Solver blue;
  class Warn red;
