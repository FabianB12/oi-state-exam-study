flowchart LR
  PAC["<b>PAC learning</b><br/>i.i.d. labeled examples<br/>goal: low true error<br/>with high probability"]
  Online["<b>Online learning</b><br/>sequence of examples<br/>predict, observe label<br/>goal: low regret or mistakes"]
  Bandit["<b>Bandits</b><br/>choose arm<br/>observe only chosen reward<br/>balance exploration/exploitation"]
  RL["<b>Reinforcement learning</b><br/>state, action, reward, next state<br/>learn policy over time"]
  Feedback["<b>Key difference</b><br/>The less feedback you observe,<br/>the harder exploration becomes."]

  PAC --> Feedback
  Online --> Feedback
  Bandit --> Feedback
  RL --> Feedback

