flowchart TB
  Rand["<b>Randomized polynomial-time algorithms</b><br/>use random bits<br/>acceptance is a probability"]

  RP["<b>RP</b><br/>yes: accept with probability at least 1/2<br/>no: never accept<br/>one-sided error"]
  CoRP["<b>co-RP</b><br/>yes: always accept<br/>no: accept with probability at most 1/2<br/>opposite one-sided error"]
  ZPP["<b>ZPP</b><br/>zero error<br/>expected polynomial time<br/>RP intersect co-RP"]
  Amp["<b>Amplification</b><br/>repeat independently<br/>error probability drops exponentially"]

  Rand --> RP
  Rand --> CoRP
  RP --> ZPP
  CoRP --> ZPP
  RP --> Amp
  CoRP --> Amp

  classDef blue fill:#EFF6FF,stroke:#2563EB,color:#172033,stroke-width:2px;
  classDef green fill:#F0FDF4,stroke:#16A34A,color:#172033,stroke-width:2px;
  classDef yellow fill:#FEFCE8,stroke:#CA8A04,color:#172033,stroke-width:2px;
  classDef neutral fill:#F8FAFC,stroke:#64748B,color:#172033,stroke-width:2px;
  class Rand neutral;
  class RP blue;
  class CoRP green;
  class ZPP yellow;
  class Amp neutral;
